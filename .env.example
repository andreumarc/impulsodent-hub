# ─── Auth ──────────────────────────────────────────────────────────────────────
# Secret for signing JWT session tokens (min 32 chars)
JWT_SECRET=change-this-to-a-random-string-of-at-least-32-characters

# Hub admin credentials (plain text for demo — hash in production)
HUB_ADMIN_EMAIL=marcandreuguerao@gmail.com
HUB_ADMIN_PASSWORD=Admin1234!
HUB_ADMIN_NAME=Administrador

# ─── Neon (PostgreSQL) ─────────────────────────────────────────────────────────
# Get these from: https://console.neon.tech → your project → Connection Details
# Use the "pooled" connection for DATABASE_URL and "direct" for DIRECT_URL
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL_CLINICPNL=https://pnl.impulsodent.com
NEXT_PUBLIC_URL_CLINICVOX=https://vox.impulsodent.com
NEXT_PUBLIC_URL_DENTALSPOT=https://spot.impulsodent.com
NEXT_PUBLIC_URL_SPENDFLOW=https://spend.impulsodent.com
NEXT_PUBLIC_URL_FICHAJE=https://fichaje.impulsodent.com
NEXT_PUBLIC_URL_ZENTRIX=https://zentrix.impulsodent.com
NEXT_PUBLIC_URL_NEXUSERP=https://nexus.impulsodent.com
NEXT_PUBLIC_URL_DENTALHR=https://hr.impulsodent.com
